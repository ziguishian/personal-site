---
import BaseLayout from './BaseLayout.astro';
import Tag from '@/components/ui/Tag.astro';
import { contentSlug } from '@/utils/content';
import { getAssetUrl } from '@/utils/assets';
import { t, type Lang, withLang } from '@/utils/i18n';
import { absoluteUrl, breadcrumbSchema } from '@/utils/seo';
import { render } from 'astro:content';

const { entry, next, lang = 'zh' } = Astro.props as any;
const { Content } = await render(entry);
const workPath = withLang(`/works/${contentSlug(entry)}`, lang);
---

<BaseLayout
  lang={lang as Lang}
  title={entry.data.seo?.title ?? entry.data.title}
  description={entry.data.seo?.description ?? entry.data.description}
  image={entry.data.ogImage ?? entry.data.cover}
  pageType="creativeWork"
  publishedTime={entry.data.date}
  updatedTime={entry.data.updated ?? entry.data.date}
  tags={entry.data.tags}
  structuredData={[
    breadcrumbSchema([
      { name: 'Home', url: withLang('/', lang) },
      { name: t(lang as Lang, 'worksTitle'), url: withLang('/works', lang) },
      { name: entry.data.title, url: workPath }
    ]),
    {
      '@type': 'Project',
      '@id': `${absoluteUrl(workPath)}#project`,
      name: entry.data.title,
      description: entry.data.description,
      url: absoluteUrl(workPath),
      image: entry.data.cover ? absoluteUrl(getAssetUrl(entry.data.cover)) : undefined,
      dateCreated: entry.data.date,
      keywords: entry.data.tags,
      creator: { '@id': 'https://alexi.tech/#person' }
    }
  ]}
>
  <article class="site-shell pb-16 pt-28 md:pb-20 lg:pt-[7.5rem]">
    <header class="grid min-h-[52vh] items-center gap-12 lg:min-h-[58vh] lg:grid-cols-[0.78fr_1.22fr]">
      <div>
        <p class="mb-8 text-sm uppercase tracking-[0.2em] text-muted">{entry.data.category}</p>
        <h1 class="text-balance text-[clamp(3.3rem,8vw,8.4rem)] font-normal leading-[0.9]">{entry.data.title}</h1>
        <p class="mt-8 max-w-xl text-xl leading-9 text-muted">{entry.data.description}</p>
      </div>
      {entry.data.cover && (
        <img class="aspect-[16/10] w-full object-cover" src={getAssetUrl(entry.data.cover)} alt={entry.data.title} loading="eager" />
      )}
    </header>
    <dl class="mt-10 grid gap-0 border-y text-sm uppercase tracking-[0.12em] hairline md:grid-cols-4">
      <div class="border-b py-6 hairline md:border-b-0 md:border-r md:px-6"><dt class="text-muted">Year</dt><dd class="mt-2">{entry.data.year}</dd></div>
      <div class="border-b py-6 hairline md:border-b-0 md:border-r md:px-6"><dt class="text-muted">Role</dt><dd class="mt-2 normal-case tracking-normal">{entry.data.role}</dd></div>
      <div class="border-b py-6 hairline md:border-b-0 md:border-r md:px-6"><dt class="text-muted">Status</dt><dd class="mt-2">{entry.data.status}</dd></div>
      <div class="py-6 md:px-6"><dt class="text-muted">Progress</dt><dd class="mt-2">{entry.data.progress ?? 0}%</dd></div>
    </dl>
    <div class="mt-8 flex flex-wrap gap-2">{entry.data.tags.map((tag: string) => <Tag text={tag} />)}</div>
    <div class="mt-20 grid gap-14 lg:grid-cols-[0.24fr_0.76fr]">
      <aside class="hidden text-sm uppercase tracking-[0.14em] text-muted lg:block">
        <div class="sticky top-28 space-y-5">
          <p>{entry.data.category}</p>
          <p>{entry.data.status}</p>
          <p>{entry.data.progress ?? 0}%</p>
        </div>
      </aside>
      <div class="prose prose-lg prose-site max-w-3xl">
        <Content />
      </div>
    </div>
    {next && (
      <a href={withLang(`/works/${contentSlug(next)}`, lang)} class="mt-24 flex items-center justify-between border-t py-8 text-2xl hairline">
        <span>{t(lang, 'nextProject')}</span>
        <span>{next.data.title} -></span>
      </a>
    )}
  </article>
</BaseLayout>
