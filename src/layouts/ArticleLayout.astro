---
import BaseLayout from './BaseLayout.astro';
import Tag from '@/components/ui/Tag.astro';
import { formatDate } from '@/utils/content';
import { t, type Lang, withLang } from '@/utils/i18n';
import { render } from 'astro:content';

const { entry, lang = 'zh' } = Astro.props as any;
const { Content } = await render(entry);
---

<BaseLayout lang={lang as Lang} title={entry.data.seo?.title ?? entry.data.title} description={entry.data.seo?.description ?? entry.data.description} image={entry.data.ogImage}>
  <article class="site-shell pb-16 pt-32 md:pb-20 lg:pt-[8.5rem]">
    <a class="text-sm uppercase tracking-[0.18em] text-muted" href={withLang('/thinking', lang)}>{t(lang, 'backThinking')}</a>
    <header class="mt-10 max-w-4xl">
      <div class="mb-8 flex flex-wrap gap-3 text-sm text-muted">
        <span>{formatDate(entry.data.date, lang)}</span>
        {entry.data.readingTime && <span>{entry.data.readingTime}</span>}
        {entry.data.tags.map((tag: string) => <Tag text={tag} />)}
      </div>
      <h1 class="text-balance text-[clamp(2.7rem,5.8vw,6.2rem)] font-normal leading-[0.96]">{entry.data.title}</h1>
      <p class="mt-8 max-w-2xl text-xl leading-9 text-muted">{entry.data.description}</p>
    </header>
    <div class="prose prose-lg prose-site mt-16 max-w-3xl">
      <Content />
    </div>
  </article>
</BaseLayout>
