---
import Header from '@/components/layout/Header.astro';
import Footer from '@/components/layout/Footer.astro';
import { defaultAssetBase, getAssetUrl } from '@/utils/assets';
import { getLangFromUrl, t, type Lang } from '@/utils/i18n';
import { absoluteUrl, alternateLinks, canonicalPath, graphSchema, personSchema, siteAuthor, siteKeywords, websiteSchema } from '@/utils/seo';
import { themeInitScript } from '@/utils/theme';
import '@/styles/global.css';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  lang?: Lang;
  noindex?: boolean;
  canonical?: string;
  pageType?: 'website' | 'article' | 'profile' | 'creativeWork';
  publishedTime?: Date | string;
  updatedTime?: Date | string;
  tags?: string[];
  structuredData?: object | object[];
}

const lang = Astro.props.lang ?? getLangFromUrl(Astro.url);
const title = Astro.props.title ? `${Astro.props.title} | Zi Gui Shi An` : 'Zi Gui Shi An';
const description =
  Astro.props.description ?? 'AI Builder / Product Designer. A quiet personal universe for works, thinking and live updates.';
const canonical = Astro.props.canonical ?? absoluteUrl(canonicalPath(Astro.url.pathname, lang));
const alternates = alternateLinks(Astro.url.pathname, lang);
const shareImagePath = Astro.props.image && !Astro.props.image.endsWith('.svg') ? Astro.props.image : '/images/og/wechat-share.jpg';
const image = absoluteUrl(getAssetUrl(shareImagePath));
const assetBase = (import.meta.env.PUBLIC_ASSET_BASE_URL || defaultAssetBase).replace(/\/$/, '');
const pageType = Astro.props.pageType ?? 'website';
const publishedTime = Astro.props.publishedTime ? new Date(Astro.props.publishedTime).toISOString() : undefined;
const updatedTime = Astro.props.updatedTime ? new Date(Astro.props.updatedTime).toISOString() : publishedTime;
const keywords = [...siteKeywords, ...(Astro.props.tags ?? [])].join(', ');
const pageSchema = {
  '@type': pageType === 'article' ? 'Article' : pageType === 'creativeWork' ? 'CreativeWork' : pageType === 'profile' ? 'ProfilePage' : 'WebPage',
  '@id': `${canonical}#webpage`,
  url: canonical,
  name: title,
  headline: title,
  description,
  image,
  inLanguage: lang === 'zh' ? 'zh-CN' : 'en-US',
  isPartOf: { '@id': `${absoluteUrl('/')}#website` },
  author: { '@id': `${absoluteUrl('/')}#person` },
  creator: { '@id': `${absoluteUrl('/')}#person` },
  publisher: { '@id': `${absoluteUrl('/')}#person` },
  datePublished: publishedTime,
  dateModified: updatedTime,
  keywords
};
const structuredData = [
  personSchema(),
  websiteSchema(lang),
  pageSchema,
  ...(Array.isArray(Astro.props.structuredData) ? Astro.props.structuredData : Astro.props.structuredData ? [Astro.props.structuredData] : [])
];
const jsonLd = JSON.stringify(graphSchema(structuredData)).replace(/</g, '\\u003c');
---

<!doctype html>
<html lang={lang === 'zh' ? 'zh-CN' : 'en-US'} data-asset-base={assetBase}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <meta name="color-scheme" content="light dark" />
    <meta name="theme-color" content="#f7f6f2" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    <script is:inline set:html={themeInitScript}></script>
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="author" content={siteAuthor} />
    <meta name="keywords" content={keywords} />
    <meta name="generator" content="Astro" />
    <link rel="canonical" href={canonical} />
    {alternates.map((alternate) => <link rel="alternate" hreflang={alternate.lang} href={alternate.href} />)}
    <link rel="alternate" type="application/rss+xml" title="Zi Gui Shi An / Thinking RSS" href={absoluteUrl('/rss.xml')} />
    <link rel="alternate" type="text/plain" title="LLM Site Summary" href={absoluteUrl('/llms.txt')} />
    <link rel="alternate" type="application/json" title="Entity Profile" href={absoluteUrl('/entity.json')} />
    <link rel="sitemap" type="application/xml" href={absoluteUrl('/sitemap-index.xml')} />
    <link rel="icon" href="/icons/favicon.svg" />
    {Astro.props.noindex && <meta name="robots" content="noindex,nofollow" />}
    {!Astro.props.noindex && <meta name="robots" content="index,follow,max-image-preview:large,max-snippet:-1,max-video-preview:-1" />}
    <meta property="og:locale" content={lang === 'zh' ? 'zh_CN' : 'en_US'} />
    <meta property="og:locale:alternate" content={lang === 'zh' ? 'en_US' : 'zh_CN'} />
    <meta property="og:type" content={pageType === 'article' ? 'article' : 'website'} />
    <meta property="og:site_name" content={t(lang, 'siteName')} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={image} />
    <meta property="og:image:secure_url" content={image} />
    <meta property="og:image:type" content="image/jpeg" />
    <meta property="og:image:width" content="800" />
    <meta property="og:image:height" content="800" />
    <meta property="og:image:alt" content={title} />
    <meta property="og:url" content={canonical} />
    {publishedTime && <meta property="article:published_time" content={publishedTime} />}
    {updatedTime && <meta property="article:modified_time" content={updatedTime} />}
    {(Astro.props.tags ?? []).map((tag) => <meta property="article:tag" content={tag} />)}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={image} />
    <script is:inline type="application/ld+json" set:html={jsonLd}></script>
  </head>
  <body>
    <div class="reading-progress" aria-hidden="true"><span></span></div>
    <img src={image} alt="" width="300" height="300" style="position:absolute;left:-9999px;top:0;width:300px;height:300px;opacity:0;pointer-events:none;" aria-hidden="true" />
    <Header lang={lang} pathname={Astro.url.pathname} />
    <main>
      <slot />
    </main>
    <Footer lang={lang} />
    <div class="site-cursor" aria-hidden="true"></div>
    <div class="site-cursor-dot" aria-hidden="true"></div>
    <script>
      const assetBase = document.documentElement.dataset.assetBase?.replace(/\/$/, '') || '';
      const normalizeAssetImage = (img: HTMLImageElement) => {
        if (!assetBase || img.dataset.assetNormalized === 'true') return;
        const rawSrc = img.getAttribute('src') || '';
        if (!rawSrc || rawSrc.startsWith('data:') || rawSrc.startsWith('blob:')) return;

        const localPathFromCdn = (value: string) => {
          try {
            const srcUrl = new URL(value, window.location.origin);
            const baseUrl = new URL(assetBase);
            if (srcUrl.origin !== baseUrl.origin) return '';
            const basePath = baseUrl.pathname.replace(/\/$/, '');
            if (!basePath || !srcUrl.pathname.startsWith(`${basePath}/`)) return '';
            return srcUrl.pathname.slice(basePath.length) || '';
          } catch {
            return '';
          }
        };

        const localFallback = rawSrc.startsWith('/images/')
          ? rawSrc
          : rawSrc.startsWith('/public/images/')
            ? rawSrc.replace(/^\/public/, '')
            : localPathFromCdn(rawSrc);

        if (!localFallback.startsWith('/images/')) return;

        img.dataset.assetNormalized = 'true';
        img.dataset.fallbackSrc = localFallback;
        img.addEventListener(
          'error',
          () => {
            const fallback = img.dataset.fallbackSrc;
            if (!fallback || img.getAttribute('src') === fallback) return;
            img.src = fallback;
          },
          { once: true }
        );

        if (rawSrc.startsWith('/images/') || rawSrc.startsWith('/public/images/')) {
          img.src = `${assetBase}${localFallback}`;
        }
      };

      const normalizeAssetImages = (root: ParentNode = document) => {
        root.querySelectorAll?.('img').forEach((image) => normalizeAssetImage(image as HTMLImageElement));
      };

      normalizeAssetImages();

      const assetImageObserver = new MutationObserver((records) => {
        records.forEach((record) => {
          record.addedNodes.forEach((node) => {
            if (!(node instanceof Element)) return;
            if (node instanceof HTMLImageElement) normalizeAssetImage(node);
            normalizeAssetImages(node);
          });
        });
      });
      assetImageObserver.observe(document.body, { childList: true, subtree: true });

      const motionQuery = window.matchMedia('(prefers-reduced-motion: reduce)');
      const candidates = [
        ...document.querySelectorAll('main > section:not(#top), article > header, article .prose-site, footer')
      ] as HTMLElement[];

      const uniqueCandidates = [...new Set(candidates)].filter((element) => !element.closest('#top')) as HTMLElement[];

      if (motionQuery.matches) {
        uniqueCandidates.forEach((element) => element.classList.add('is-visible'));
      } else {
        uniqueCandidates.forEach((element, index) => {
          element.classList.add('scroll-reveal');
          element.dataset.reveal ||= index % 2 === 0 ? 'rise' : 'soft';
          element.style.setProperty('--reveal-delay', '0ms');
          element.addEventListener(
            'transitionend',
            (event) => {
              if (event.propertyName !== 'transform') return;
              element.classList.add('reveal-settled');
            },
            { once: true }
          );
        });

        const observer = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (!entry.isIntersecting) return;
              entry.target.classList.add('is-visible');
              observer.unobserve(entry.target);
            });
          },
          { rootMargin: '-32% 0px -36% 0px', threshold: 0.01 }
        );

        uniqueCandidates.forEach((element) => observer.observe(element));
      }

      const cursorQuery = window.matchMedia('(hover: hover) and (pointer: fine)');
      const cursor = document.querySelector('.site-cursor') as HTMLElement | null;
      const cursorDot = document.querySelector('.site-cursor-dot') as HTMLElement | null;

      if (cursorQuery.matches && cursor && cursorDot) {
        document.body.classList.add('has-orbital-cursor');
        let targetX = window.innerWidth / 2;
        let targetY = window.innerHeight / 2;
        let cursorX = targetX;
        let cursorY = targetY;
        let frame = 0;

        const moveCursor = () => {
          cursorX += (targetX - cursorX) * 0.22;
          cursorY += (targetY - cursorY) * 0.22;
          cursor.style.transform = `translate3d(${cursorX}px, ${cursorY}px, 0) translate(-50%, -50%)`;
          cursorDot.style.transform = `translate3d(${targetX}px, ${targetY}px, 0) translate(-50%, -50%)`;
          frame = requestAnimationFrame(moveCursor);
        };

        const updateHover = (target: EventTarget | null) => {
          const element = target instanceof Element ? target : null;
          const hovering = Boolean(element?.closest('a, button, [role="button"], input, textarea, select, summary'));
          cursor.classList.toggle('is-hovering', hovering);
        };

        window.addEventListener(
          'pointermove',
          (event) => {
            targetX = event.clientX;
            targetY = event.clientY;
            cursor.classList.add('is-visible');
            cursorDot.classList.add('is-visible');
            updateHover(event.target);
          },
          { passive: true }
        );

        window.addEventListener('pointerdown', () => cursor.classList.add('is-pressing'));
        window.addEventListener('pointerup', () => cursor.classList.remove('is-pressing'));
        document.addEventListener('mouseleave', () => {
          cursor.classList.remove('is-visible', 'is-hovering', 'is-pressing');
          cursorDot.classList.remove('is-visible');
        });
        frame = requestAnimationFrame(moveCursor);
        window.addEventListener('pagehide', () => cancelAnimationFrame(frame), { once: true });
      }

      const progress = document.querySelector('.reading-progress') as HTMLElement | null;
      const progressBar = progress?.querySelector('span') as HTMLElement | null;
      const shouldTrackReading =
        Boolean(document.querySelector('article')) ||
        window.location.search.includes('slug=') ||
        /\/(thinking|works)\/[^/]+/.test(window.location.pathname);

      if (progress && progressBar && shouldTrackReading) {
        progress.classList.add('is-active');
        const updateProgress = () => {
          const scrollable = document.documentElement.scrollHeight - window.innerHeight;
          const value = scrollable > 0 ? Math.min(1, Math.max(0, window.scrollY / scrollable)) : 0;
          progressBar.style.transform = `scaleX(${value})`;
        };
        updateProgress();
        window.addEventListener('scroll', updateProgress, { passive: true });
        window.addEventListener('resize', updateProgress);
      }

      const enhanceCodeBlocks = (root: ParentNode = document) => {
        const isZh = document.documentElement.lang.toLowerCase().startsWith('zh');
        root.querySelectorAll('pre').forEach((pre) => {
          const block = pre as HTMLPreElement;
          if (block.dataset.codeEnhanced === 'true') return;
          const code = block.querySelector('code');
          if (!code) return;

          block.dataset.codeEnhanced = 'true';
          const language = block.dataset.language || [...code.classList]
            .find((className) => className.startsWith('language-'))
            ?.replace('language-', '');
          if (language) block.dataset.codeLanguage = language.toUpperCase();

          const button = document.createElement('button');
          button.type = 'button';
          button.className = 'code-copy-button';
          button.setAttribute('aria-label', isZh ? '复制代码' : 'Copy code');
          button.textContent = isZh ? '复制' : 'Copy';
          button.addEventListener('click', async () => {
            const text = code.textContent || '';
            try {
              await navigator.clipboard.writeText(text);
              button.dataset.copied = 'true';
              button.textContent = isZh ? '已复制' : 'Copied';
              window.setTimeout(() => {
                button.dataset.copied = 'false';
                button.textContent = isZh ? '复制' : 'Copy';
              }, 1500);
            } catch {
              button.textContent = isZh ? '复制失败' : 'Failed';
              window.setTimeout(() => {
                button.textContent = isZh ? '复制' : 'Copy';
              }, 1500);
            }
          });

          block.append(button);
        });
      };

      enhanceCodeBlocks();
      const codeObserver = new MutationObserver((mutations) => {
        mutations.forEach((mutation) => {
          mutation.addedNodes.forEach((node) => {
            if (node instanceof Element) enhanceCodeBlocks(node);
          });
        });
      });
      codeObserver.observe(document.body, { childList: true, subtree: true });
      window.addEventListener('pagehide', () => codeObserver.disconnect(), { once: true });
    </script>
  </body>
</html>
