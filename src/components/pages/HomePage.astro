---
import BaseLayout from '@/layouts/BaseLayout.astro';
import UniverseHero from '@/components/three/UniverseHero.astro';
import SectionLabel from '@/components/ui/SectionLabel.astro';
import LiveCard from '@/components/ui/LiveCard.astro';
import Button from '@/components/ui/Button.astro';
import { t, type Lang, withLang } from '@/utils/i18n';

interface Props { lang: Lang }
const { lang } = Astro.props;
---

<BaseLayout
  lang={lang}
  title={lang === 'zh' ? '子圭时安｜师健鑫 Alexi Shi' : 'Alexi Shi | Zi Gui Shi An'}
  description={
    lang === 'zh'
      ? '师健鑫，英文名 Alexi Shi，网络身份子圭时安，过去曾用名师兄白泽。00后创业者、极客设计师、AI 创作者，长期探索 AIGC、产品设计、全栈开发、工业设计、创业与星际探索。'
      : 'Alexi Shi, also known as Zi Gui Shi An and formerly Shixiong Baize, is a Gen-Z entrepreneur, geek designer and AI creator exploring AIGC, product design, full-stack development, industrial design, startups and space exploration.'
  }
>
  <script is:inline>
    document.body.classList.add('home-mobile-reference');
  </script>
  <section id="top" class="home-hero relative min-h-screen overflow-hidden pt-24" data-scroll-cue>
    <div class="orbital-hero-bg pointer-events-none absolute right-[-54vw] top-28 z-0 block h-[48vh] min-h-[320px] w-[132vw] opacity-[0.34] sm:right-[-32vw] sm:top-20 sm:h-[52vh] sm:w-[112vw] sm:opacity-[0.28] lg:pointer-events-auto lg:bottom-20 lg:left-[19vw] lg:right-[-11vw] lg:top-24 lg:h-auto lg:min-h-0 lg:w-auto lg:opacity-85">
      <UniverseHero />
    </div>
    <div class="site-shell relative z-10 grid min-h-[calc(100vh-6rem)] items-center lg:items-start lg:pt-[13.5vh]">
      <div class="home-hero-copy max-w-lg pb-[24vh] lg:pb-0">
      <p class="mb-6 text-xs uppercase tracking-[0.12em] text-muted sm:text-sm lg:mb-7">{t(lang, 'heroRole')}</p>
      <h1 class="home-hero-title text-balance text-[clamp(2.85rem,13vw,5rem)] font-normal leading-[0.94] lg:text-[clamp(3.6rem,5.8vw,6.7rem)]">{t(lang, 'heroName')}</h1>
      {lang === 'zh' && <p class="mt-6 text-2xl font-semibold lg:mt-7">— {t(lang, 'heroCnName')} —</p>}
      <p class="mt-8 text-[clamp(1.08rem,4.4vw,1.32rem)] leading-relaxed lg:mt-9 lg:text-[clamp(1.12rem,1.25vw,1.38rem)]">{t(lang, 'heroBelief')}</p>
      <p class="home-hero-position mt-7 max-w-md text-sm leading-7 text-muted lg:text-base">{t(lang, 'heroPositioning')}</p>
      <div class="mt-12 lg:mt-16"><Button href={withLang('/universe', lang)} label={t(lang, 'explore')} /></div>
      </div>
    </div>
  </section>

  <section class="home-now home-focus site-shell section-space border-t hairline" data-scroll-cue>
    <div class="grid gap-12 lg:grid-cols-[0.28fr_1fr]">
      <SectionLabel eyebrow={lang === 'zh' ? '01 / 焦点' : '01 / Focus'} title={t(lang, 'nowTitle')} intro={t(lang, 'nowIntro')} />
      <div class="home-focus-grid grid gap-4 md:grid-cols-3">
        <LiveCard title={lang === 'zh' ? '[Building]' : '[Building]'} value={lang === 'zh' ? '灵矩绘境' : 'Lingju Vision'} description={lang === 'zh' ? '探索艺术与 AI 的边界' : 'Exploring the edge of art and AI'} progress={65} progressLabel={t(lang, 'progress')} />
        <LiveCard icon="circle" title={lang === 'zh' ? '[Incubating]' : '[Incubating]'} value={lang === 'zh' ? '子圭时安' : 'Zi Gui Shi An'} description={lang === 'zh' ? '超级个体 IP 的自我迭代' : 'A personal IP in public'} />
        <LiveCard icon="sparkle" title={lang === 'zh' ? '[Thinking]' : '[Thinking]'} value={lang === 'zh' ? '人类文明' : 'Human Civilization'} description={lang === 'zh' ? 'AGI、星际探索与长期主义' : 'AGI, space and long-termism'} />
      </div>
    </div>
  </section>

  <section class="home-works home-node-section site-shell section-space border-t hairline" data-scroll-cue data-runtime-home data-lang={lang} data-works-base={withLang('/works', lang)} data-thinking-base={withLang('/thinking', lang)}>
    <div class="grid gap-12 lg:grid-cols-[0.2fr_1fr]">
      <div class="flex flex-col justify-between gap-10">
        <SectionLabel eyebrow={lang === 'zh' ? '02 / 作品' : '02 / Works'} title={t(lang, 'worksTitle')} intro={t(lang, 'worksIntro')} />
        <Button href={withLang('/works', lang)} label={t(lang, 'viewAllWorks')} />
      </div>
      <div class="home-work-grid grid gap-6 md:grid-cols-3" data-home-works></div>
    </div>
    <div class="home-work-showcase" aria-label={lang === 'zh' ? '精选项目视觉展示' : 'Selected work visuals'}>
      <div class="home-work-showcase-intro">
        <p>{lang === 'zh' ? 'Creation systems' : 'Creation systems'}</p>
        <h3>{lang === 'zh' ? '三个长期构建的创造系统' : 'Three long-term creation systems'}</h3>
        <span>{lang === 'zh' ? '创作、知识与个人宇宙' : 'Creation, knowledge and personal universe'}</span>
      </div>
      <div class="home-work-showcase-gallery">
        {[
          { src: '/images/works/lingju/cover.svg', title: lang === 'zh' ? '灵矩绘境' : 'Lingju Vision', meta: 'AIGC × C2M CREATION SYSTEM' },
          { src: '/images/works/shian-ai/cover.svg', title: lang === 'zh' ? '子圭时安个人 IP' : 'Zi Gui Shi An Personal IP', meta: 'PUBLIC IDENTITY / CREATOR SYSTEM' },
          { src: '/images/works/compound-practice/cover.svg', title: lang === 'zh' ? '子圭时安数字花园' : 'Zi Gui Shi An Digital Garden', meta: 'WRITING / IP / KNOWLEDGE SYSTEM' }
        ].map((item, index) => (
          <figure class="home-work-showcase-item" style={`--i:${index}`} data-showcase-card>
            <img src={item.src} alt={item.title} loading="lazy" />
            <figcaption>
              <span>{String(index + 1).padStart(2, '0')}</span>
              <strong>{item.title}</strong>
              <em>{item.meta}</em>
            </figcaption>
          </figure>
        ))}
      </div>
    </div>
  </section>

  <section class="home-thinking home-node-section site-shell section-space border-t hairline" data-scroll-cue>
    <div class="grid gap-12 lg:grid-cols-[0.2fr_1fr]">
      <div class="flex flex-col justify-between gap-10">
        <SectionLabel eyebrow={lang === 'zh' ? '03 / 思考' : '03 / Thinking'} title={t(lang, 'thinkingTitle')} intro={t(lang, 'thinkingIntro')} />
        <Button href={withLang('/thinking', lang)} label={t(lang, 'viewAllArticles')} />
      </div>
      <div class="home-thinking-grid grid gap-0 md:grid-cols-2" data-home-thinking></div>
    </div>
  </section>

  <section class="home-about home-node-section site-shell section-space border-t hairline" data-scroll-cue>
    <SectionLabel eyebrow={lang === 'zh' ? '04 / 关于' : '04 / About'} title={t(lang, 'aboutTitle')} />
    <div class="mt-12 grid items-center gap-12 lg:grid-cols-[0.44fr_0.34fr_0.22fr]">
      <img class="h-auto max-w-full object-contain" src="/images/about/portrait.png" alt="Zi Gui Shi An" loading="lazy" />
      <div class:list={['space-y-6', lang === 'zh' ? 'text-xl leading-10' : 'text-lg leading-8']}>
        {lang === 'zh' ? (
          <>
            <p>00后创业者 / 极客设计师 / AIGC 探索者。</p>
            <p>痴迷 AIGC 与星际探索，爱 Coding、阅读与清茶。</p>
            <p>正在构建「灵矩绘境」，探索艺术、AI 与制造之间的边界。</p>
          </>
        ) : (
          <>
            <p>Gen-Z entrepreneur / geek designer / AIGC explorer.</p>
            <p>Obsessed with AI, interstellar exploration, coding, reading and quiet tea.</p>
            <p>Building Lingju Vision to explore the boundary between art, AI and manufacturing.</p>
          </>
        )}
        <Button href={withLang('/about', lang)} label={t(lang, 'moreAbout')} />
      </div>
      <ol class="space-y-7 border-l pl-8 text-base hairline lg:text-lg">
        {(lang === 'zh' ? ['产品设计', 'AI 原生', '创业实践', '系统思维'] : ['Product Design', 'AI Native', 'Entrepreneurship', 'Systems Thinking']).map((item, index) => (
          <li class="flex items-baseline gap-6 whitespace-nowrap"><span class="w-8 shrink-0 text-muted">{String(index + 1).padStart(2, '0')}</span><span>{item}</span></li>
        ))}
      </ol>
    </div>
    <div class="home-about-metrics" data-countup-root>
      {[
        { value: 5, suffix: '+', label: lang === 'zh' ? '工作年限' : 'Years Building', note: lang === 'zh' ? '从工程、设计到创业实践' : 'Engineering, design and startups' },
        { value: 12, suffix: '', label: lang === 'zh' ? '荣誉奖项' : 'Honors', note: lang === 'zh' ? '竞赛、创业与专业成长' : 'Competitions and craft growth' },
        { value: 2000, suffix: '+', label: lang === 'zh' ? '社交媒体粉丝' : 'Social Audience', note: lang === 'zh' ? '记录思考与构建过程' : 'Sharing thoughts and builds' }
      ].map((metric) => (
        <article class="home-about-metric">
          <p><span data-countup data-target={metric.value}>0</span>{metric.suffix}</p>
          <h3>{metric.label}</h3>
          <small>{metric.note}</small>
        </article>
      ))}
    </div>
    <p class="home-about-metric-note">
      {lang === 'zh'
        ? '数字来自产品、设计、研发、创业实践与公开内容沉淀；它们不是终点，而是持续构建的刻度。'
        : 'These numbers come from product, design, engineering, startup practice and public writing. They are markers of a continuing build.'}
    </p>
  </section>

  <section class="home-live home-node-section site-shell section-space border-t hairline" data-scroll-cue>
    <div class="mb-10 flex flex-col justify-between gap-6 md:flex-row md:items-end">
      <SectionLabel eyebrow={lang === 'zh' ? '05 / 动态' : '05 / Live'} title={t(lang, 'liveTitle')} />
      <Button href={withLang('/live', lang)} label={t(lang, 'viewLive')} />
    </div>
    <div class="grid gap-5 md:grid-cols-4">
      <LiveCard title={lang === 'zh' ? 'Now Building' : 'Now Building'} value={lang === 'zh' ? '灵矩绘境小程序' : 'Lingju Vision Mini Program'} description={lang === 'zh' ? 'AIGC 与定制化电商融合平台' : 'AIGC and custom commerce platform'} progress={80} progressLabel={t(lang, 'progress')} />
      <LiveCard icon="circle" title={lang === 'zh' ? 'Now Incubating' : 'Now Incubating'} value={lang === 'zh' ? '子圭时安' : 'Zi Gui Shi An'} description={lang === 'zh' ? '超级个体 IP 的自我迭代' : 'A personal IP in public'} />
      <LiveCard icon="users" title={lang === 'zh' ? 'Founder Of' : 'Founder Of'} value={lang === 'zh' ? '渡阡科技 / 灵矩绘境' : 'Duqian Tech / Lingju'} description={lang === 'zh' ? '从产品到制造' : 'Product to manufacturing'} />
      <LiveCard icon="sparkle" title={lang === 'zh' ? 'Latest Signal' : 'Latest Signal'} value={lang === 'zh' ? '人类文明' : 'Human Civilization'} description={lang === 'zh' ? 'AI、星际与长期主义' : 'AI, space and long-termism'} />
    </div>
    <div class="home-live-cta">
      <p>{lang === 'zh' ? '如果你也在构建 AI 原生产品，欢迎通过微信 ziguishian 交流。' : 'If you are building AI-native products too, connect with me on WeChat: ziguishian.'}</p>
      <a href={withLang('/manifesto', lang)}>{lang === 'zh' ? '阅读宣言' : 'Read Manifesto'} →</a>
    </div>
  </section>
  <script>
    import { mountRuntimeHome } from '@/utils/runtimeContent';
    document.querySelectorAll<HTMLElement>('[data-runtime-home]').forEach((root) => {
      mountRuntimeHome(root);
    });

    const metricRoots = document.querySelectorAll<HTMLElement>('[data-countup-root]');
    const motionReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const formatValue = (value: number) => new Intl.NumberFormat(document.documentElement.lang.startsWith('zh') ? 'zh-CN' : 'en-US').format(value);
    const runCountUp = (root: HTMLElement) => {
      if (root.dataset.counted === 'true') return;
      root.dataset.counted = 'true';
      root.querySelectorAll<HTMLElement>('[data-countup]').forEach((node) => {
        const target = Number(node.dataset.target || 0);
        if (motionReduced) {
          node.textContent = formatValue(target);
          return;
        }
        const duration = 1100;
        const start = performance.now();
        const tick = (now: number) => {
          const progress = Math.min(1, (now - start) / duration);
          const eased = 1 - Math.pow(1 - progress, 3);
          node.textContent = formatValue(Math.round(target * eased));
          if (progress < 1) requestAnimationFrame(tick);
        };
        requestAnimationFrame(tick);
      });
    };

    if (metricRoots.length) {
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (!entry.isIntersecting) return;
            runCountUp(entry.target as HTMLElement);
            observer.unobserve(entry.target);
          });
        },
        { threshold: 0.35 }
      );
      metricRoots.forEach((root) => observer.observe(root));
    }

    const showcaseCards = Array.from(document.querySelectorAll<HTMLElement>('[data-showcase-card]'));
    const setupWorkShowcase = () => {
      if (!showcaseCards.length) return;
      if (motionReduced) {
        showcaseCards.forEach((card) => card.classList.add('is-visible'));
        return;
      }

      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (!entry.isIntersecting) return;
            entry.target.classList.add('is-visible');
            observer.unobserve(entry.target);
          });
        },
        { rootMargin: '-16% 0px -18% 0px', threshold: 0.12 }
      );

      showcaseCards.forEach((card) => observer.observe(card));
    };

    setupWorkShowcase();
  </script>
</BaseLayout>
