---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { t, type Lang, withLang } from '@/utils/i18n';

interface Props { lang: Lang }
const { lang } = Astro.props;
---

<BaseLayout lang={lang} title={t(lang, 'thinkingTitle')} description={t(lang, 'thinkingIntro')}>
  <section class="site-shell pb-16 pt-32 md:pb-20 md:pt-36" data-runtime-thinking data-lang={lang} data-base={withLang('/thinking', lang)}>
    <header>
      <p class="mb-8 text-sm uppercase tracking-[0.18em] text-muted">{t(lang, 'thinkingEyebrow')}</p>
      <h1 class="text-balance text-[clamp(3rem,7.4vw,7rem)] font-normal leading-[0.94]">{t(lang, 'thinkingTitle')}</h1>
      <p class="mt-10 max-w-2xl text-xl leading-9 text-muted md:text-2xl md:leading-10">{t(lang, 'thinkingIntro')}</p>
      <div class="mt-12 flex flex-col gap-4 md:flex-row md:items-center md:justify-between" data-runtime-controls></div>
    </header>
    <p class="mt-12 text-sm uppercase tracking-[0.16em] text-muted" data-runtime-status></p>
    <div class="mt-14" data-runtime-content></div>
  </section>
  <script>
    import { mountRuntimeThinking } from '@/utils/runtimeContent';
    document.querySelectorAll<HTMLElement>('[data-runtime-thinking]').forEach((root) => {
      mountRuntimeThinking(root);
    });
  </script>
</BaseLayout>
