---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { t, type Lang, withLang } from '@/utils/i18n';

interface Props { lang: Lang }
const { lang } = Astro.props;
---

<BaseLayout lang={lang} title={t(lang, 'worksTitle')} description={t(lang, 'worksIntro')}>
  <section class="site-shell pb-28 pt-32 md:pt-36" data-runtime-works data-lang={lang} data-base={withLang('/works', lang)}>
    <header data-runtime-list-header>
      <p class="mb-8 text-sm uppercase tracking-[0.18em] text-muted">{t(lang, 'worksEyebrow')}</p>
      <h1 class="text-balance text-[clamp(3.2rem,8vw,8rem)] font-normal leading-[0.9]">{t(lang, 'worksTitle')}</h1>
      <p class="mt-10 max-w-2xl text-xl leading-9 text-muted md:text-2xl md:leading-10">{t(lang, 'worksIntro')}</p>
      <div class="mt-12" data-runtime-controls></div>
    </header>
    <p class="mt-12 text-sm uppercase tracking-[0.16em] text-muted" data-runtime-status></p>
    <div class="mt-14" data-runtime-content></div>
  </section>
  <script>
    import { mountRuntimeWorks } from '@/utils/runtimeContent';
    document.querySelectorAll<HTMLElement>('[data-runtime-works]').forEach((root) => {
      mountRuntimeWorks(root);
    });
  </script>
</BaseLayout>
