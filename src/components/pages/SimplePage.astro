---
import BaseLayout from '@/layouts/BaseLayout.astro';
import UniverseHero from '@/components/three/UniverseHero.astro';
import LiveCard from '@/components/ui/LiveCard.astro';
import { t, type Lang, withLang } from '@/utils/i18n';

interface Props { lang: Lang; page: 'about' | 'live' | 'lab' | 'system' | 'manifesto' | 'universe' | 'uses' | 'faq' }
const { lang, page } = Astro.props;
const titleMap = {
  about: t(lang, 'aboutTitle'),
  live: t(lang, 'liveTitle'),
  lab: t(lang, 'labTitle'),
  system: t(lang, 'systemTitle'),
  manifesto: t(lang, 'manifesto'),
  universe: t(lang, 'universeTitle'),
  uses: lang === 'zh' ? 'Uses / 工具栈' : 'Uses',
  faq: lang === 'zh' ? 'FAQ / 常见问题' : 'FAQ'
};
const descriptionMap = {
  about:
    lang === 'zh'
      ? '师健鑫，英文名 Alexi Shi，网络身份子圭时安，过去曾用名师兄白泽。00后创业者、极客设计师、AI 创作者，长期探索 AIGC、产品设计、全栈开发、工业设计、创业实践与星际探索。'
      : 'Alexi Shi, also known as Zi Gui Shi An and formerly Shixiong Baize, is a Gen-Z entrepreneur, geek designer and AI creator exploring AIGC, product design, full-stack development, industrial design, startups and space exploration.',
  live: lang === 'zh' ? '子圭时安正在构建、写作、探索和公开更新的现场。' : 'Live updates from Alexi Shi across building, writing, learning and public creation.',
  lab: lang === 'zh' ? '未完成的小工具、AI 实验、demo 与概念验证。' : 'Small tools, AI experiments, demos and proofs of concept.',
  system: lang === 'zh' ? '子圭时安关于系统思维、AI 原生、长期主义和创造驱动的方法论。' : 'Alexi Shi on systems thinking, AI-native building, long-termism and creation-driven work.',
  manifesto: lang === 'zh' ? '让我们一起加速 AGI 的实现，让劳作归于算法，让灵魂奔向星辰。' : 'Accelerate AGI. Let labor return to algorithms. Let the soul run toward the stars.',
  universe: t(lang, 'universeSubtitle'),
  uses:
    lang === 'zh'
      ? '子圭时安的工具栈、技术栈、创作系统、设计工具、开发环境与日常工作流。'
      : 'The tools, technology stack, creative system, design setup, development environment and daily workflow used by Alexi Shi.',
  faq:
    lang === 'zh'
      ? '关于师健鑫、子圭时安、Alexi Shi、灵矩绘境、AIGC、个人网站与合作方式的常见问题。'
      : 'Frequently asked questions about Alexi Shi, Zi Gui Shi An, Lingju Vision, AIGC, this website and collaboration.'
};
const identities = lang === 'zh'
  ? ['00后创业者', '极客设计师', 'AIGC 探索者', '工业设计 / 全栈开发']
  : ['Gen-Z Entrepreneur', 'Geek Designer', 'AIGC Explorer', 'Industrial Design / Full-Stack'];
const capabilities = lang === 'zh'
  ? ['AI & 神经网络', 'Vue / Node.js / Java', 'Figma / Rhino / Adobe CC', '产品从 0 到 1', '团队管理', 'C2M 制造探索']
  : ['AI & Neural Networks', 'Vue / Node.js / Java', 'Figma / Rhino / Adobe CC', '0-to-1 Product Building', 'Team Leadership', 'C2M Manufacturing'];
const supplies = lang === 'zh'
  ? ['阅读', 'Coding', '写作', '看电影', '喝茶', '火星移民', '喜欢独处']
  : ['Reading', 'Coding', 'Writing', 'Cinema', 'Tea', 'Mars Migration', 'Solitude'];
const timeline = lang === 'zh'
  ? [
      ['2015', '14岁开始自学编程，用 Java 建立对逻辑世界的最初认知。'],
      ['2018', '17岁通过产品化变现，完成从需求分析到商业闭环的第一次验证。'],
      ['2019', '18岁步入社会，随后前往北京开启 Java 开发工程师职业生涯。'],
      ['2020', '19岁首次创业，创办渡阡科技，打造灵活用工平台 Freeworkers。'],
      ['2021', '以社会考生身份参加高考，攻读工业设计，将技术底色与设计美学结合。'],
      ['2022', '获得 CSDN 软件精英挑战赛全国二等奖，并在创业竞赛和内容创作中持续验证。'],
      ['2023', '入职字节跳动从事社区类 APP 前端开发，成为国内首批 AI 应用层探索者之一。'],
      ['2024', '担任灵极科技 CTO，负责 AI 应用层研发，推进语音交互生图产品。'],
      ['2025', '创办灵矩绘境，将 AIGC 与 C2M 制造结合，让灵感成为生活实物。']
    ]
  : [
      ['2015', 'Started self-learning programming at 14 and built an early sense of logic through Java.'],
      ['2018', 'Validated product monetization at 17 and completed the first demand-to-business loop.'],
      ['2019', 'Entered society at 18, then moved to Beijing to begin a Java developer career.'],
      ['2020', 'Founded Duqian Technology at 19 and built Freeworkers, a flexible work platform.'],
      ['2021', 'Returned to school through the national exam and studied Industrial Design.'],
      ['2022', 'Won national second prize in the CSDN Software Elite Challenge and kept testing startup ideas.'],
      ['2023', 'Joined ByteDance for community-app frontend work and explored early AI application products.'],
      ['2024', 'Served as CTO of Lingji Technology and led AI application-layer product development.'],
      ['2025', 'Founded Lingju Vision, combining AIGC and C2M manufacturing to turn inspiration into objects.']
    ];
const usesGroups = lang === 'zh'
  ? [
      {
        title: '开发环境',
        intro: '我更偏好能快速进入心流、足够稳定、又允许高度定制的工具。',
        items: ['MacBook / macOS', 'VS Code / Cursor / Codex', 'Astro / TypeScript / Tailwind CSS', 'Vue / Node.js / Java', 'MySQL / MongoDB / Redis', 'GitHub / Git']
      },
      {
        title: '设计与产品',
        intro: '从抽象想法到可见界面，我会尽量把设计、产品和工程放在同一张桌子上。',
        items: ['Figma', 'Rhino', 'Adobe Photoshop / Illustrator / Premiere', '剪映', 'Midjourney / Gemini / AIGC 工作流', '产品原型 / 信息架构 / 设计系统']
      },
      {
        title: '知识与创作',
        intro: '输入、整理、输出、验证，是我长期维护自己的方式。',
        items: ['语雀 / 数字花园', 'Markdown', '微信公众号 / 小红书 / Bilibili', '阅读系统', '播客与随笔', 'Build in Public']
      },
      {
        title: '生活系统',
        intro: '代码之外，我用一些安静的习惯保持清醒。',
        items: ['阅读', '写作', '清茶', '电影', '独处', '星际探索 / 火星移民']
      }
    ]
  : [
      {
        title: 'Development',
        intro: 'I prefer tools that are stable, fast to enter flow with, and open enough to customize.',
        items: ['MacBook / macOS', 'VS Code / Cursor / Codex', 'Astro / TypeScript / Tailwind CSS', 'Vue / Node.js / Java', 'MySQL / MongoDB / Redis', 'GitHub / Git']
      },
      {
        title: 'Design & Product',
        intro: 'I try to keep design, product thinking and engineering on the same table.',
        items: ['Figma', 'Rhino', 'Adobe Photoshop / Illustrator / Premiere', 'CapCut', 'Midjourney / Gemini / AIGC workflows', 'Prototyping / IA / Design systems']
      },
      {
        title: 'Knowledge & Creation',
        intro: 'Input, organize, output and validate: this is how I maintain a long-term creative system.',
        items: ['Yuque / Digital garden', 'Markdown', 'WeChat / Xiaohongshu / Bilibili', 'Reading system', 'Podcast and notes', 'Build in Public']
      },
      {
        title: 'Life System',
        intro: 'Beyond code, I keep myself clear through quiet habits.',
        items: ['Reading', 'Writing', 'Tea', 'Cinema', 'Solitude', 'Space exploration / Mars migration']
      }
    ];
const faqItems = lang === 'zh'
  ? [
      ['师健鑫是谁？', '师健鑫，英文名 Alexi Shi，网络身份子圭时安，过去曾用名师兄白泽，是一名 00 后创业者、极客设计师与 AI 创作者。'],
      ['子圭时安是谁？', '子圭时安是师健鑫的公开网络身份，用来记录 AI 产品、AIGC、产品设计、创业实践、系统思考与长期主义。'],
      ['Alexi Shi 和师健鑫是同一个人吗？', '是。Alexi Shi / Alex Shi / Alexi、师健鑫、子圭时安、ziguishian 以及过去曾用名师兄白泽，都指向同一个人。'],
      ['灵矩绘境是什么？', '灵矩绘境是一个将 AIGC 与定制化电商深度融合的平台，目标是让灵感从生成、预览、定制到购买形成完整闭环。'],
      ['alexi.tech 是什么？', 'alexi.tech 是子圭时安的个人数字空间，不是普通简历页，而是长期维护的作品集、数字花园、公开构建档案与个人世界观入口。'],
      ['这个网站适合通过什么方式联系？', '目前最推荐通过微信 ziguishian 联系，适合交流 AI、产品设计、AIGC、创业、技术实现与潜在合作。'],
      ['这个网站的内容如何更新？', '网站核心内容来自 Markdown、运行时内容索引和图片资源。部署后可以通过内容文件和 CDN 图片路径持续维护。'],
      ['子圭时安关注哪些方向？', '主要关注 AIGC、AI 原生产品、产品设计、全栈开发、工业设计、C2M 定制制造、系统思维、长期主义、火星移民与星际探索。']
    ]
  : [
      ['Who is Alexi Shi?', 'Alexi Shi, also known as Zi Gui Shi An and formerly Shixiong Baize, is a Gen-Z entrepreneur, geek designer and AI creator from China.'],
      ['Who is Zi Gui Shi An?', 'Zi Gui Shi An is the public identity of Alexi Shi, used to document AI products, AIGC, product design, startup practice, systems thinking and long-term building.'],
      ['Are Alexi Shi and Shi Jianxin the same person?', 'Yes. Alexi Shi, Alex Shi, Alexi, Shi Jianxin, Zi Gui Shi An, ziguishian and the former name Shixiong Baize refer to the same person.'],
      ['What is Lingju Vision?', 'Lingju Vision is a platform that combines AIGC and customized commerce, aiming to turn inspiration into purchasable physical products.'],
      ['What is alexi.tech?', 'alexi.tech is the personal digital space of Alexi Shi: a portfolio, digital garden, build-in-public archive and worldview entry point.'],
      ['How can I contact Alexi Shi?', 'The preferred contact channel is WeChat: ziguishian, especially for conversations around AI, product design, AIGC, startups and collaboration.'],
      ['How is this website maintained?', 'The site is maintained through Markdown content, runtime content indexes and CDN-first image assets.'],
      ['What topics does Alexi Shi focus on?', 'AIGC, AI-native products, product design, full-stack development, industrial design, C2M manufacturing, systems thinking, long-termism, Mars migration and space exploration.']
    ];
const faqStructuredData = {
  '@type': 'FAQPage',
  mainEntity: faqItems.map(([question, answer]) => ({
    '@type': 'Question',
    name: question,
    acceptedAnswer: {
      '@type': 'Answer',
      text: answer
    }
  }))
};
---

<BaseLayout
  lang={lang}
  title={titleMap[page]}
  description={descriptionMap[page]}
  pageType={page === 'about' ? 'profile' : 'website'}
  structuredData={page === 'faq' ? faqStructuredData : undefined}
>
  {page === 'universe' && (
    <section class="relative min-h-screen pt-24">
      <div class="absolute inset-0 pt-20"><UniverseHero mode="map" /></div>
      <div class="site-shell relative z-10 grid min-h-[calc(100vh-6rem)] place-items-center pb-10 pt-4 text-center md:pb-12 md:pt-0">
        <div class="mx-auto w-full max-w-5xl -translate-y-8 md:-translate-y-10">
          <h1 class="text-[clamp(4rem,9vw,9rem)] font-normal leading-[0.9]">{t(lang, 'universeTitle')}</h1>
          <p class="mt-10 text-2xl leading-10 text-muted">{t(lang, 'universeSubtitle')}</p>
          <div class="mx-auto mt-12 grid w-full max-w-4xl gap-3 sm:grid-cols-2 lg:grid-cols-4">
            {[
              ['works', t(lang, 'works')],
              ['thinking', t(lang, 'thinking')],
              ['live', t(lang, 'live')],
              ['about', t(lang, 'about')],
              ['lab', t(lang, 'lab')],
              ['uses', lang === 'zh' ? '工具栈' : 'Uses'],
              ['faq', 'FAQ'],
              ['system', t(lang, 'system')],
              ['manifesto', t(lang, 'manifesto')]
            ].map(([href, label]) => (
              <a class="whitespace-nowrap border px-6 py-5 text-lg hairline transition-colors hover:bg-text hover:text-bg lg:text-xl" href={withLang(`/${href}`, lang)}>{label}</a>
            ))}
          </div>
        </div>
      </div>
    </section>
  )}

  {page === 'about' && (
    <section class="site-shell pb-16 pt-36 md:pb-20">
      <p class="mb-8 text-sm uppercase tracking-[0.18em] text-muted">{t(lang, 'aboutEyebrow')}</p>
      <h1 class="text-[clamp(4rem,9vw,9rem)] font-normal leading-[0.9]">{t(lang, 'aboutTitle')}</h1>
      <div class="mt-16 grid gap-12 lg:grid-cols-[0.55fr_0.45fr]">
        <img src="/images/about/portrait.png" alt="Zi Gui Shi An" class="h-auto max-w-full object-contain" />
        <div class="space-y-10 text-xl leading-10">
          <p>{t(lang, 'aboutNarrative')}</p>
          <p class="text-muted">
            {lang === 'zh'
              ? '中文名：师健鑫。英文名：Alexi / Alex Shi。网络身份：子圭时安。过去曾用名：师兄白泽。浙江，人工智能方向。长期相信：火星移民终将实现，AGI 将放大人类创造力。'
              : 'Chinese name: Shi Jianxin. English name: Alexi / Alex Shi. Online identity: Zi Gui Shi An. Former name: Shixiong Baize. Based in Zhejiang, focused on artificial intelligence. I believe AGI will amplify human creativity and Mars migration will eventually happen.'}
          </p>
          <div class="grid gap-4 sm:grid-cols-2">
            {identities.map((item) => <div class="border p-6 hairline">{item}</div>)}
          </div>
          <div>
            <p class="mb-4 text-sm uppercase tracking-[0.16em] text-muted">{lang === 'zh' ? '当前状态' : 'Status'}</p>
            <div class="space-y-3 text-base leading-8 text-[color:color-mix(in_srgb,var(--text)_82%,var(--muted))]">
              <p>{lang === 'zh' ? '[Building] 灵矩绘境 · 探索艺术与 AI 的边界' : '[Building] Lingju Vision · exploring the edge of art and AI'}</p>
              <p>{lang === 'zh' ? '[Incubating] 超级个体 IP「子圭时安」的自我迭代' : '[Incubating] Zi Gui Shi An as a personal IP'}</p>
              <p>{lang === 'zh' ? '[Thinking] 人类文明、AGI、星际探索与长期主义' : '[Thinking] Human civilization, AGI, space exploration and long-termism'}</p>
            </div>
          </div>
          <div>
            <p class="mb-4 text-sm uppercase tracking-[0.16em] text-muted">{lang === 'zh' ? '能力矩阵' : 'Capability Matrix'}</p>
            <div class="flex flex-wrap gap-2">
              {capabilities.map((item) => <span class="border px-3 py-2 text-sm text-muted hairline">{item}</span>)}
            </div>
          </div>
          <div>
            <p class="mb-4 text-sm uppercase tracking-[0.16em] text-muted">{lang === 'zh' ? '精神补给：代码之外' : 'Beyond Code'}</p>
            <div class="flex flex-wrap gap-2">
              {supplies.map((item) => <span class="border px-3 py-2 text-sm text-muted hairline">{item}</span>)}
            </div>
          </div>
          <a class="inline-flex border-b pb-1 uppercase tracking-[0.12em]" href="#wechat-contact">{t(lang, 'contactCta')}</a>
        </div>
      </div>
      <div class="mt-24 border-t pt-14 hairline">
        <p class="mb-10 text-sm uppercase tracking-[0.18em] text-muted">{lang === 'zh' ? '个人履历 / Timeline' : 'Timeline'}</p>
        <ol class="grid gap-0">
          {timeline.map(([year, text]) => (
            <li class="grid gap-6 border-t py-7 hairline md:grid-cols-[0.18fr_1fr]">
              <span class="text-2xl text-muted">{year}</span>
              <p class="max-w-3xl text-xl leading-9">{text}</p>
            </li>
          ))}
        </ol>
      </div>
    </section>
  )}

  {page === 'live' && (
    <section class="site-shell pb-16 pt-36 md:pb-20" data-runtime-live data-lang={lang}>
      <h1 class="text-[clamp(4rem,9vw,9rem)] font-normal leading-[0.9]">{t(lang, 'liveTitle')}</h1>
      <div class="mt-16 grid gap-5 md:grid-cols-4">
        <LiveCard title={t(lang, 'building')} value={t(lang, 'liveBuildingValue')} progress={65} progressLabel={t(lang, 'progress')} />
        <LiveCard icon="circle" title={lang === 'zh' ? '孵化中' : 'Incubating'} value={lang === 'zh' ? '超级个体 IP' : 'Personal IP'} />
        <LiveCard icon="sparkle" title={lang === 'zh' ? '思考中' : 'Thinking'} value={lang === 'zh' ? '人类文明' : 'Human Civilization'} />
        <LiveCard icon="users" title={lang === 'zh' ? '微信' : 'WeChat'} value="ziguishian" />
      </div>
      <div class="mt-16 grid gap-6" data-runtime-content></div>
    </section>
  )}

  {page === 'lab' && (
    <section class="site-shell pb-16 pt-36 md:pb-20" data-runtime-lab data-lang={lang} data-base={withLang('/lab', lang)}>
      <h1 class="text-[clamp(4rem,9vw,9rem)] font-normal leading-[0.9]">{t(lang, 'labTitle')}</h1>
      <div class="mt-16" data-runtime-content></div>
    </section>
  )}

  {page === 'system' && (
    <section class="site-shell pb-16 pt-36 md:pb-20">
      <h1 class="text-[clamp(4rem,9vw,9rem)] font-normal leading-[0.9]">{titleMap.system}</h1>
      <div class="mt-20 grid gap-5 md:grid-cols-4">
        {(lang === 'zh'
          ? ['知行合一', 'AI 原生', '成长重于成功', '少即是多']
          : ['Knowledge In Action', 'AI Native', 'Growth Over Success', 'Less But Better']
        ).map((item, index) => (
          <div class="relative min-h-72 border p-8 hairline">
            <span class="text-muted">{String(index + 1).padStart(2, '0')}</span>
            <h2 class="mt-20 text-3xl">{item}</h2>
            <div class="absolute bottom-8 left-8 right-8 h-px bg-text/30"></div>
          </div>
        ))}
      </div>
    </section>
  )}

  {page === 'uses' && (
    <section class="site-shell pb-16 pt-36 md:pb-20">
      <p class="mb-8 text-sm uppercase tracking-[0.18em] text-muted">{lang === 'zh' ? '工具 / 工作流' : 'Tools / Workflow'}</p>
      <div class="grid gap-12 lg:grid-cols-[0.38fr_0.62fr] lg:items-end">
        <h1 class="text-[clamp(4rem,9vw,9rem)] font-normal leading-[0.9]">{titleMap.uses}</h1>
        <p class="max-w-2xl text-xl leading-9 text-muted">{descriptionMap.uses}</p>
      </div>
      <div class="mt-20 grid gap-0 border-t hairline">
        {usesGroups.map((group, index) => (
          <section class="grid gap-8 border-b py-10 hairline lg:grid-cols-[0.28fr_0.72fr]">
            <div>
              <span class="text-sm uppercase tracking-[0.16em] text-muted">{String(index + 1).padStart(2, '0')}</span>
              <h2 class="mt-5 text-[clamp(2rem,4vw,4rem)] font-normal leading-none">{group.title}</h2>
            </div>
            <div>
              <p class="max-w-3xl text-xl leading-9 text-muted">{group.intro}</p>
              <div class="mt-8 grid gap-3 sm:grid-cols-2">
                {group.items.map((item) => (
                  <div class="border px-5 py-4 text-base hairline md:text-lg">{item}</div>
                ))}
              </div>
            </div>
          </section>
        ))}
      </div>
      <div class="mt-16 border-y py-10 hairline">
        <p class="max-w-4xl text-[clamp(1.8rem,3vw,3.4rem)] leading-tight">
          {lang === 'zh'
            ? '我选择工具的标准不是流行，而是它能不能进入长期系统，帮助我更快地把想法变成可验证的作品。'
            : 'I choose tools not because they are fashionable, but because they can enter a long-term system and help turn ideas into verifiable work.'}
        </p>
      </div>
    </section>
  )}

  {page === 'faq' && (
    <section class="site-shell pb-16 pt-36 md:pb-20">
      <p class="mb-8 text-sm uppercase tracking-[0.18em] text-muted">{lang === 'zh' ? '问答 / 实体说明' : 'Questions / Entity Notes'}</p>
      <div class="grid gap-12 lg:grid-cols-[0.38fr_0.62fr] lg:items-end">
        <h1 class="text-[clamp(4rem,9vw,9rem)] font-normal leading-[0.9]">{titleMap.faq}</h1>
        <p class="max-w-2xl text-xl leading-9 text-muted">{descriptionMap.faq}</p>
      </div>
      <div class="mt-20 border-t hairline">
        {faqItems.map(([question, answer], index) => (
          <details class="group border-b py-8 hairline" open={index < 2}>
            <summary class="flex cursor-pointer list-none items-start justify-between gap-8 text-2xl leading-tight md:text-3xl">
              <span class="grid gap-3 md:grid-cols-[4rem_1fr]">
                <span class="text-base text-muted">{String(index + 1).padStart(2, '0')}</span>
                <span>{question}</span>
              </span>
              <span class="mt-1 text-muted transition-transform group-open:rotate-45">+</span>
            </summary>
            <p class="mt-6 max-w-3xl pl-0 text-lg leading-9 text-muted md:ml-16 md:text-xl">{answer}</p>
          </details>
        ))}
      </div>
      <div class="mt-16 grid gap-4 sm:grid-cols-3">
        <a class="border p-6 hairline transition-colors hover:bg-text hover:text-bg" href={withLang('/about', lang)}>{lang === 'zh' ? '查看关于我' : 'View About'}</a>
        <a class="border p-6 hairline transition-colors hover:bg-text hover:text-bg" href={withLang('/works', lang)}>{lang === 'zh' ? '查看作品' : 'View Works'}</a>
        <a class="border p-6 hairline transition-colors hover:bg-text hover:text-bg" href={withLang('/uses', lang)}>{lang === 'zh' ? '查看工具栈' : 'View Uses'}</a>
      </div>
    </section>
  )}

  {page === 'manifesto' && (
    <section class="site-shell grid min-h-screen place-items-center pt-24 text-center">
      <div class="mx-auto max-w-5xl">
        <p class="grid gap-5 text-[clamp(2rem,5.2vw,5rem)] font-normal leading-[1.18] tracking-[-0.02em]">
          {(lang === 'zh'
            ? ['让我们一起加速 AGI 的实现', '让劳作归于算法', '让灵魂奔向星辰']
            : ['Accelerate AGI.', 'Let labor return to algorithms.', 'Let the soul run toward the stars.']
          ).map((line) => <span>{line}</span>)}
        </p>
      </div>
    </section>
  )}
  <script>
    import { mountRuntimeLab, mountRuntimeLive } from '@/utils/runtimeContent';
    document.querySelectorAll<HTMLElement>('[data-runtime-live]').forEach((root) => {
      mountRuntimeLive(root);
    });
    document.querySelectorAll<HTMLElement>('[data-runtime-lab]').forEach((root) => {
      mountRuntimeLab(root);
    });
  </script>
</BaseLayout>
