---
import { ArrowRight } from 'lucide-astro';
import Tag from './Tag.astro';
interface Props {
  href: string;
  number?: string;
  date?: string;
  title: string;
  description: string;
  tags?: string[];
  readingTime?: string;
}
const { href, number, date, title, description, tags = [], readingTime } = Astro.props;
---

<a href={href} class="group grid gap-6 border-t py-8 hairline md:grid-cols-[0.18fr_1fr_0.25fr_auto]">
  <div class="text-xl text-muted">{number ?? date}</div>
  <div>
    <h3 class="text-2xl font-medium">{title}</h3>
    <p class="mt-3 max-w-2xl text-lg leading-8 text-muted">{description}</p>
    <div class="mt-5 flex flex-wrap gap-2">{tags.map((tag) => <Tag text={tag} />)}</div>
  </div>
  <div class="text-sm uppercase tracking-[0.14em] text-muted">{readingTime}</div>
  <ArrowRight class="self-center transition-transform group-hover:translate-x-1" size={28} strokeWidth={1.35} />
</a>
