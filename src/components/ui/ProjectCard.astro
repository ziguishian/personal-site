---
import { ArrowRight } from 'lucide-astro';
import { getAssetUrl } from '@/utils/assets';
interface Props {
  href: string;
  number: string;
  title: string;
  description: string;
  cover?: string;
  tag?: string;
}
const { href, number, title, description, cover, tag } = Astro.props;
---

<a href={href} class="group relative block overflow-hidden border bg-surface transition-transform duration-300 hairline hover:-translate-y-1">
  <div class="relative aspect-[16/11] overflow-hidden bg-text/5">
    {cover ? <img src={getAssetUrl(cover)} alt={title} class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-[1.03]" loading="lazy" /> : null}
    <span class="absolute left-6 top-5 text-3xl text-white mix-blend-difference">{number}</span>
    {tag && <span class="absolute right-5 top-5 border border-white/35 px-2 py-1 text-[0.62rem] uppercase tracking-[0.12em] text-white/85 backdrop-blur-sm">{tag}</span>}
  </div>
  <div class="p-7">
    <div class="mb-5 flex items-center gap-4">
      <h3 class="text-2xl font-semibold">{title}</h3>
    </div>
    <div class="flex items-end justify-between gap-6">
      <p class="text-lg leading-8 text-muted">{description}</p>
      <ArrowRight class="shrink-0 transition-transform group-hover:translate-x-1" size={26} strokeWidth={1.35} />
    </div>
  </div>
</a>
