---
import { Menu, X } from 'lucide-astro';
import ThemeToggle from './ThemeToggle.astro';
import LanguageSwitch from './LanguageSwitch.astro';
import { navItems, t, type Lang, withLang } from '@/utils/i18n';

interface Props { lang: Lang; pathname: string }
const { lang, pathname } = Astro.props;
---

<header class="site-header fixed inset-x-0 top-0 z-50 border-b border-transparent bg-transparent">
  <div class="site-shell flex h-20 items-center justify-between">
    <a href={withLang('/', lang)} class="flex items-center gap-4 focus-ring" aria-label="Zi Gui Shi An home">
      <span class="grid h-11 w-11 place-items-center rounded-full">
        <span class="relative h-7 w-px bg-text before:absolute before:left-1/2 before:top-1/2 before:h-3 before:w-3 before:-translate-x-1/2 before:-translate-y-1/2 before:rounded-full before:bg-text"></span>
      </span>
      <span class="text-sm uppercase tracking-[0.18em]">{t(lang, 'logoName')}</span>
    </a>
    <nav class="hidden items-center gap-10 text-sm uppercase md:flex">
      {navItems.map((item) => (
        <a class:list={['focus-ring transition-opacity hover:opacity-55', pathname.includes(item.href) && 'opacity-55']} href={withLang(item.href, lang)}>
          {t(lang, item.key)}
        </a>
      ))}
      <ThemeToggle />
      <LanguageSwitch lang={lang} pathname={pathname} />
    </nav>
    <button class="focus-ring grid h-11 w-11 place-items-center rounded-full border hairline md:hidden" data-menu-button aria-label="Open menu">
      <Menu size={18} strokeWidth={1.45} data-menu-open />
      <X size={18} strokeWidth={1.45} class="hidden" data-menu-close />
    </button>
  </div>
  <div class="mobile-menu-panel hidden md:hidden" data-mobile-menu>
    <nav class="grid gap-4 text-2xl">
      {navItems.map((item) => <a class="block border-b py-3 hairline" href={withLang(item.href, lang)}>{t(lang, item.key)}</a>)}
      <div class="mobile-menu-controls mt-3 flex flex-wrap items-center justify-between gap-4">
        <ThemeToggle />
        <LanguageSwitch lang={lang} pathname={pathname} />
      </div>
    </nav>
  </div>
</header>

<script>
  const button = document.querySelector('[data-menu-button]');
  const menu = document.querySelector('[data-mobile-menu]');
  const header = document.querySelector('.site-header');
  const openIcon = document.querySelector('[data-menu-open]');
  const closeIcon = document.querySelector('[data-menu-close]');
  const setMenuOpen = (open: boolean) => {
    menu?.classList.toggle('hidden', !open);
    header?.classList.toggle('is-menu-open', open);
    openIcon?.classList.toggle('hidden', open);
    closeIcon?.classList.toggle('hidden', !open);
  };

  button?.addEventListener('click', (event) => {
    event.stopPropagation();
    setMenuOpen(Boolean(menu?.classList.contains('hidden')));
  });

  menu?.addEventListener('click', (event) => {
    event.stopPropagation();
  });

  document.addEventListener('click', () => {
    if (!menu?.classList.contains('hidden')) setMenuOpen(false);
  });

  window.addEventListener('keydown', (event) => {
    if (event.key === 'Escape') setMenuOpen(false);
  });

  const getBrandHideLimit = () => {
    const title =
      document.querySelector<HTMLElement>('.home-hero-title') ||
      document.querySelector<HTMLElement>('main h1');
    if (!title) return 72;
    const titleTop = title.getBoundingClientRect().top + window.scrollY;
    return Math.max(72, titleTop - 28);
  };

  const syncHeader = () => {
    const currentScrollY = window.scrollY;
    const brandHideLimit = getBrandHideLimit();
    header?.classList.toggle('is-scrolled', currentScrollY > 18);
    header?.classList.toggle('is-brand-hidden', currentScrollY > brandHideLimit);
  };
  syncHeader();
  window.addEventListener('scroll', syncHeader, { passive: true });
  window.addEventListener('resize', syncHeader);
</script>
